{
  "name": "picos-ttrpg-toolkit",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted, system-agnostic TTRPG Game Master toolkit (single-user, LAN-only).",
  "license": "UNLICENSED",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start.ps1",
    "start:bash": "bash scripts/start.sh",
    "dev": "concurrently -n server,web -c blue,magenta \"npm:dev -w apps/server\" \"npm:dev -w apps/web\"",
    "build": "npm run build -w packages/shared && npm run build -w apps/server && npm run build -w apps/web",
    "serve": "npm run start -w apps/server",
    "migrate": "npm run migrate -w apps/server",
    "seed": "npm run seed -w apps/server",
    "check": "npm run check --workspaces --if-present",
    "test": "npm run test -w apps/server"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
