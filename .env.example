# Copy to .env at the repo root and fill in.

# Backend port (apps/server). Vite dev proxies /api -> http://localhost:PORT.
PORT=3000

# SQLite file (relative to apps/server). Prisma reads this verbatim.
DATABASE_URL="file:./data/app.db"

# Where uploaded images live (relative to apps/server).
UPLOAD_DIR="./data/uploads"

# 32 random bytes, base64. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_KEY=""

# Initial GM password used by the seed script (only used the first time the DB
# is created; after that, change the password through the app once it has one).
GM_PASSWORD="changeme"

# In production, set to 'production'.
NODE_ENV=development
