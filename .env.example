# Copy to .env at the repo root and fill in. Only DATABASE_URL, SESSION_KEY, and
# GM_PASSWORD are required — the rest are shown here for reference but fall back
# to the defaults in apps/server/src/env.ts if omitted.

# Backend port (apps/server). Vite dev proxies /api -> http://localhost:PORT.
# (optional, default 3000)
PORT=3000

# SQLite file (relative to apps/server). Prisma reads this verbatim.
DATABASE_URL="file:./data/app.db"

# Where uploaded images live (relative to apps/server).
# (optional, default ./data/uploads)
UPLOAD_DIR="./data/uploads"

# Secret that encrypts/signs the login session cookie. Leave blank and the server
# auto-generates one on first boot, persisting it to apps/server/data/session.key
# (stable across restarts). Set it explicitly in production — 32 random bytes,
# base64: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# (optional)
SESSION_KEY=""

# Bootstrap Game Master account. The seed script (npm run seed) creates the first
# DM user from these and makes them DM of existing campaigns. Re-running seed
# updates this user's password. Others self-register in the app.
GM_USERNAME="gm"          # (optional, default "gm")
GM_PASSWORD="changeme"    # (required only to run `npm run seed`)

# In production, set to 'production'. (optional, default development)
NODE_ENV=development
