// Prisma schema for Pico's TTRPG Toolkit. SQLite has no native JSON, so all
// JSON-shaped columns are stored as TEXT and validated with zod at the
// repository layer on both read and write.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  displayName  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships  Membership[]
  characters   PartyMember[]
  diceRolls    DiceRoll[]
  spells       Spell[]       @relation("UserSpell")
  npcs         NPC[]         @relation("UserNpc")
  monsters     Monster[]     @relation("UserMonster")
}

model Membership {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  role       String   @default("player") // dm|player
  createdAt  DateTime @default(now())

  @@unique([userId, campaignId])
  @@index([campaignId])
}

model Campaign {
  id          String   @id @default(cuid())
  name        String
  description String?
  tagsJson    String   @default("[]")
  joinCode    String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  layout       Layout?
  memberships  Membership[]
  sessions     Session[]
  party        PartyMember[]
  npcs         NPC[]
  monsters     Monster[]
  spells       Spell[]
  locations    Location[]
  shops        Shop[]
  encounters   Encounter[]
  calendar     Calendar?
  weather      Weather?
  log          LogEntry[]
  diceRolls    DiceRoll[]
  broadcasts   Broadcast[]
  clocks       ProgressClock[]
  timers       Timer[]
  rollTables   RollTable[]
  assets       Asset[]
}

model Layout {
  id            String   @id @default(cuid())
  campaignId    String   @unique
  campaign      Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  itemsJson     String   @default("[]")
  viewportX     Float    @default(0)
  viewportY     Float    @default(0)
  viewportScale Float    @default(1)
  updatedAt     DateTime @updatedAt
}

model Broadcast {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  widgetKey  String
  active     Boolean  @default(false)
  payloadJson String  @default("{}")
  updatedAt  DateTime @updatedAt

  @@unique([campaignId, widgetKey])
}

model Asset {
  id         String    @id @default(cuid())
  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  filename   String
  mime       String
  size       Int
  createdAt  DateTime  @default(now())

  @@index([campaignId])
}

model PartyMember {
  id              String   @id @default(cuid())
  campaignId      String
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  name            String
  playerName      String?
  hp              Int      @default(0)
  hpMax           Int      @default(0)
  gold            Int      @default(0)
  status          String   @default("active") // active|down|stable|dead
  conditionsJson  String   @default("[]")
  notes           String?
  portraitAssetId String?
  statsJson       String   @default("{}")
  order           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([campaignId, userId])
  @@index([campaignId, order])
}

model Session {
  id                String   @id @default(cuid())
  campaignId        String
  campaign          Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  title             String
  date              DateTime?
  summary           String?
  notes             String?  // markdown body
  externalLinksJson String   @default("[]")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([campaignId, date])
}

model NPC {
  id              String     @id @default(cuid())
  campaignId      String?
  campaign        Campaign?  @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  ownerUserId     String?
  owner           User?      @relation("UserNpc", fields: [ownerUserId], references: [id], onDelete: Cascade)
  name            String
  role            String?
  quirk           String?
  hook            String?
  notes           String?
  tagsJson        String     @default("[]")
  portraitAssetId String?
  favorite        Boolean    @default(false)
  locationId      String?
  location        Location?  @relation(fields: [locationId], references: [id], onDelete: SetNull)
  statsJson       String     @default("{}")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([ownerUserId])
}

model Monster {
  id          String   @id @default(cuid())
  campaignId  String?
  campaign    Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  ownerUserId String?
  owner       User?    @relation("UserMonster", fields: [ownerUserId], references: [id], onDelete: Cascade)
  name        String
  type        String?
  environment String?
  challenge   String?
  statsJson   String   @default("{}")
  notes       String?
  tagsJson    String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ownerUserId])
}

model Spell {
  id            String    @id @default(cuid())
  campaignId    String?
  campaign      Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  ownerUserId   String?
  owner         User?     @relation("UserSpell", fields: [ownerUserId], references: [id], onDelete: Cascade)
  name          String
  // Wikidot page slug for imported spells; null for custom ones. SQLite
  // treats NULLs as distinct, so many custom spells coexist with the unique index.
  slug          String?   @unique
  level         Int       @default(0)
  school        String?
  castingTime   String?
  range         String?
  components    String?
  duration      String?
  description   String    @default("")
  higherLevels  String?
  classesJson   String    @default("[]")
  ritual        Boolean   @default(false)
  concentration Boolean   @default(false)
  source        String?
  tagsJson      String    @default("[]")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([ownerUserId])
}

model Location {
  id           String   @id @default(cuid())
  campaignId   String
  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  gmNotes      String?
  playerNotes  String?
  imageAssetId String?
  pinsJson     String   @default("[]")
  // Polygon/rect fog-of-war reveals; player view subtracts hidden, then composites.
  revealsJson  String   @default("[]")
  // Movable tokens (PCs/monsters); fog-filtered out of the player view.
  tokensJson   String   @default("[]")
  // Optional snap grid config (null = no grid).
  gridJson     String?
  npcs         NPC[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Shop {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name       String
  notes      String?
  items      ShopItem[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ShopItem {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name      String
  type      String?
  price     Float?
  stock     Int?
  rarity    String?
  tagsJson  String   @default("[]")
}

model Encounter {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name        String
  round       Int      @default(1)
  currentTurn Int      @default(0)
  active      Boolean  @default(false)
  combatants  Combatant[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Combatant {
  id             String    @id @default(cuid())
  encounterId    String
  encounter      Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  name           String
  initiative     Int
  hp             Int?
  hpMax          Int?
  ac             Int?
  defeated       Boolean   @default(false)
  conditionsJson String    @default("[]")
  notes          String?
  isPC           Boolean   @default(false)
  order          Int       @default(0)
}

model Calendar {
  id            String   @id @default(cuid())
  campaignId    String   @unique
  campaign      Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  // { monthNames: [...], daysPerMonth: [n,n,...], weekdayNames: [...] }
  definitionJson String  @default("{}")
  currentYear   Int      @default(1)
  currentMonth  Int      @default(1)
  currentDay    Int      @default(1)
  currentHour   Int      @default(8)
  currentMinute Int      @default(0)
}

model Weather {
  id          String   @id @default(cuid())
  campaignId  String   @unique
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  // { condition, temperature, description }
  currentJson String   @default("{}")
  tableJson   String?
}

model LogEntry {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  kind       String
  message    String
  dataJson   String?
  createdAt  DateTime @default(now())

  @@index([campaignId, createdAt])
}

model ProgressClock {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name        String
  segments    Int      @default(6)
  filled      Int      @default(0)
  description String?
  color       String   @default("#6366f1")
  secret      Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([campaignId, order])
}

model Timer {
  id               String    @id @default(cuid())
  campaignId       String
  campaign         Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name             String
  durationSeconds  Int       @default(300)
  endsAt           DateTime?
  remainingSeconds Int       @default(300)
  color            String    @default("#ef4444")
  secret           Boolean   @default(false)
  order            Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([campaignId, order])
}

model RollTable {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name        String
  description String?
  // [{ weight: Int, text: String }]
  entriesJson String   @default("[]")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([campaignId, order])
}

model DiceRoll {
  id            String   @id @default(cuid())
  campaignId    String?
  campaign      Campaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  notation      String
  result        Int
  breakdownJson String
  label         String?
  hidden        Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([campaignId, createdAt])
}
