{
  "name": "@toolkit/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run db:ensure",
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=../../.env dist/index.js",
    "db:ensure": "npm run prisma:generate && npm run migrate:deploy",
    "migrate": "dotenv -e ../../.env -- prisma migrate dev --schema=prisma/schema.prisma",
    "migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy --schema=prisma/schema.prisma",
    "preseed": "npm run db:ensure",
    "seed": "tsx --env-file=../../.env prisma/seed.ts",
    "test": "node --import tsx --test --experimental-test-module-mocks \"test/**/*.test.ts\"",
    "prisma:generate": "dotenv -e ../../.env -- prisma generate --schema=prisma/schema.prisma",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit && dotenv -e ../../.env -- prisma validate --schema=prisma/schema.prisma"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.1",
    "@fastify/multipart": "^9.0.1",
    "@fastify/secure-session": "^8.1.0",
    "@fastify/static": "^8.0.3",
    "@prisma/client": "^5.22.0",
    "@toolkit/shared": "*",
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "fastify": "^5.1.0",
    "pino-pretty": "^11.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.9.0",
    "dotenv-cli": "^7.4.4",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
